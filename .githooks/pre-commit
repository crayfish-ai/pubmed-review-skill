#!/bin/bash
# Pre-commit hook: detect secrets before they enter git history
#
# To enable: git config core.hooksPath .githooks

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
CHECKER="$PROJECT_DIR/scripts/check_secrets.py"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED_FILES" ]; then
    echo "[pre-commit] No staged files, skipping check"
    exit 0
fi

if [ -f "$CHECKER" ]; then
    echo "[pre-commit] Running secret check..."
    STAGED_LIST=$(echo "$STAGED_FILES" | tr '\n' ',')
    RESULT=$(python3 "$CHECKER" --files "$STAGED_LIST" 2>&1)
    if [ $? -ne 0 ]; then
        echo "$RESULT"
        echo ""
        echo "[pre-commit] ❌ Commit blocked - secrets detected"
        echo "To bypass (USE WITH CAUTION): git commit --no-verify -m '...'"
        exit 1
    fi
    echo "[pre-commit] ✅ Secret check passed"
else
    echo "[pre-commit] ⚠️ check_secrets.py not found, skipping"
fi
